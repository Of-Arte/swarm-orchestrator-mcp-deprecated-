{
  "mcp.servers": {
    "swarm": {
      "command": "docker",
      "args": ["exec", "-i", "swarm-mcp-server", "fastmcp", "run", "server.py"],
      "env": {}
    },
    "swarm-local": {
      "command": "python",
      "args": ["-m", "fastmcp", "run", "server.py"],
      "cwd": "/path/to/swarm",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "OPENAI_API_KEY": "YOUR_KEY_HERE",
        "GEMINI_API_KEY": "YOUR_KEY_HERE"
      }
    }
  }
}
